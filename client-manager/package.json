{
  "name": "letutech-client-manager",
  "version": "1.0.0",
  "description": "LetUsTech Client & Job Manager",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win"
  },
  "build": {
    "appId": "uk.letustech.client-manager",
    "productName": "LetUsTech Client Manager",
    "directories": { "output": "dist" },
    "files": ["main.js", "preload.js", "src/**/*"],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "LetUsTech Client Manager"
    }
  },
  "author": "LetUsTech <letustec@gmail.com>",
  "license": "MIT",
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  }
}
