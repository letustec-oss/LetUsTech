{
  "name": "data-analyzer-pro",
  "version": "1.0.0",
  "description": "Advanced CSV data analysis with AI insights",
  "main": "main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/letustec-oss/LetUsTech.git"
  },
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --dir",
    "build:win": "electron-builder --win --dir",
    "build:mac": "electron-builder --mac --dir",
    "build:linux": "electron-builder --linux --dir",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "uk.letustech.data-analyzer-pro",
    "productName": "Data Analyzer Pro",
    "directories": { "output": "dist" },
    "files": ["main.js", "preload.js", "src/**/*"],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "src/assets/icon.png"
    },
    "mac": {
      "target": [{ "target": "dmg", "arch": ["x64", "arm64"] }],
      "icon": "src/assets/icon.png"
    },
    "linux": {
      "target": [{ "target": "AppImage", "arch": ["x64"] }],
      "icon": "src/assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "keywords": ["csv", "data", "analytics", "electron"],
  "author": "LetUsTech <letustech.uk>",
  "license": "MIT",
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  }
}